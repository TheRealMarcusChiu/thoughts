{
  "name": "quartz-plugin-recent-sidebar",
  "version": "1.0.0",
  "description": "Left-sidebar list of the most recent dated pages (title + date, linked).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./components": { "types": "./dist/components/index.d.ts", "import": "./dist/components/index.js" }
  },
  "quartz": {
    "name": "recent-sidebar",
    "displayName": "Recent Sidebar",
    "category": "component",
    "version": "1.0.0",
    "defaultEnabled": true,
    "components": {
      "RecentSidebar": {
        "displayName": "Recent Sidebar",
        "defaultPosition": "left",
        "defaultPriority": 40
      }
    }
  }
}
