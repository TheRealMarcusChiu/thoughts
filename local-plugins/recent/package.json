{
  "name": "quartz-plugin-recent",
  "version": "1.0.0",
  "description": "Replace a ```recent``` code block with a list of index.md pages, most recent first (title + date, linked).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "quartz": {
    "name": "recent",
    "displayName": "Recent",
    "category": "transformer",
    "version": "1.0.0",
    "defaultEnabled": true
  }
}
